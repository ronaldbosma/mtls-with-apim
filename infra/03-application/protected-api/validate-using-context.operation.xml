<policies>
    <inbound>
        <base />

        <choose>
			<!-- Return a 401 Unauthorized if no client certificate was provided -->
            <when condition="@(context.Request.Certificate == null)">
                <return-response>
                    <set-status code="401" reason="Client certificate missing" />
                </return-response>
            </when>

			<!--
				Return a 401 Unauthorized
                - if validate-certificate-chain is true but the client certificate or its chain is invalid
                - or if the client certificate is not yet valid or has expired
                - or if the provided client certificate is not a known certificate in API Management that we trust
			-->
            <when condition="@{
                  var now = DateTime.Now; // We're using DateTime.Now because NotBefore and NotAfter are in local time
                  return ({{validate-certificate-chain}} && !context.Request.Certificate.VerifyNoRevocation()) ||
                      context.Request.Certificate.NotBefore > now ||
                      context.Request.Certificate.NotAfter < now ||
                      !context.Deployment.Certificates.Any(c => c.Value.Thumbprint == context.Request.Certificate.Thumbprint);
            }">
                <return-response>
                    <set-status code="401" reason="Invalid client certificate" />
                </return-response>
            </when>
        </choose>

        <!-- Returns a 200 OK with the client certificate details in the body -->
        <return-response>
            <set-status code="200" />
            <set-body>@(context.Request.Certificate.ToString())</set-body>
        </return-response>
    </inbound>

    <backend>
        <base />
    </backend>

    <outbound>
        <base />
    </outbound>

    <on-error>
        <set-header name="ErrorSource" exists-action="override">
            <value>@(context.LastError.Source)</value>
        </set-header>
        <set-header name="ErrorReason" exists-action="override">
            <value>@(context.LastError.Reason)</value>
        </set-header>
        <set-header name="ErrorMessage" exists-action="override">
            <value>@(context.LastError.Message)</value>
        </set-header>
        <base />
    </on-error>
</policies>
